# =============================================================================
# DoNotes Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram to get your token
DONOTES_TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your Telegram user ID (get it from @userinfobot). Restricts bot access to you only.
DONOTES_TELEGRAM_ALLOWED_USER_IDS=[123456789]

# --- OpenAI ---
# Get your API key from https://platform.openai.com/api-keys
DONOTES_OPENAI_API_KEY=sk-...
DONOTES_OPENAI_MODEL=gpt-4o

# --- Google APIs ---
# Path to your OAuth credentials.json from Google Cloud Console
DONOTES_GOOGLE_CREDENTIALS_PATH=data/google_tokens/credentials.json
DONOTES_GOOGLE_TOKEN_PATH=data/google_tokens/token.json
# Gmail address to send digest emails FROM and TO (typically the same)
DONOTES_GMAIL_SENDER_EMAIL=you@gmail.com
DONOTES_GMAIL_RECIPIENT_EMAIL=you@gmail.com
# Google Calendar IDs (usually your email addresses)
DONOTES_WORK_CALENDAR_ID=you@work.com
DONOTES_PERSONAL_CALENDAR_ID=you@gmail.com

# --- Google Sheets (auto-populated on first run, or set manually) ---
DONOTES_GOOGLE_SHEET_ID=

# --- Timezone ---
DONOTES_TIMEZONE=UTC

# --- Your Name (used in AI prompts) ---
DONOTES_USER_NAME=Your Name

# --- Whisper Settings ---
DONOTES_WHISPER_MODEL=distil-large-v3
DONOTES_WHISPER_BATCH_SIZE=12

# --- Morning Brief Schedule ---
DONOTES_MORNING_BRIEF_HOUR=8
DONOTES_MORNING_BRIEF_MINUTE=0
DONOTES_WEEKLY_DIGEST_DAY=monday
DONOTES_WEEKLY_DIGEST_HOUR=9
